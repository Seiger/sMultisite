{
  "name": "seiger/smultisite",
  "license": "GPL-3.0-or-later",
  "type": "evolution-cms-module",
  "description": "Multisite and multi-domain management module for Evolution CMS.",
  "keywords": [
    "evocms",
    "evolution-cms",
    "multisite",
    "multidomain",
    "evolution-cms-domain",
    "multisite-tools",
    "cms-multisite",
    "evolution-cms-plugin"
  ],
  "authors": [
    {
      "name": "Serhii Korneliuk",
      "email": "info@seigerit.com"
    }
  ],
  "require": {
    "php": "^8.3",
    "evolution-cms/evolution": "^3.5"
  },
  "autoload": {
    "psr-4": {
      "Seiger\\sMultisite\\": "src/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Seiger\\sMultisite\\sMultisiteServiceProvider"
      ]
    }
  },
  "config": {
    "exclude-files": [
      "/docs",
      "/docs/**",
      "/.git/*",
      "/.github/*",
      "/.idea/*",
      "README.md",
      "LICENSE"
    ]
  },
  "scripts": {
    "post-autoload-dump": [],
    "post-install-cmd": [
      "@php artisan smultisite:publish"
    ],
    "post-update-cmd": [
      "@php artisan smultisite:publish"
    ]
  }
}
